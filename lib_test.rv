import std/string
import std/test { assert_eq_int, assert_eq_str, assert_true, assert_false }
import "./lib" { decode, char_width, width, visible_width, truncate, pad_left, pad_right, center }

fun test_width_ascii() {
    assert_eq_int(width("hello"), 5)
}

fun test_width_empty() {
    assert_eq_int(width(""), 0)
}

fun test_width_cjk() {
    assert_eq_int(width("你好"), 4)
    assert_eq_int(width("ラーメン"), 8)
    assert_eq_int(width("한국"), 4)
}

fun test_width_mixed() {
    assert_eq_int(width("a你b"), 4)
}

fun test_width_combining_mark() {
    // e followed by a combining acute accent draws as one column.
    assert_eq_int(width("é"), 1)
}

fun test_width_zero_width_joiner() {
    assert_eq_int(width("‍"), 0)
}

fun test_width_control() {
    assert_eq_int(width("\t"), 0)
    assert_eq_int(width("\n"), 0)
}

fun test_width_emoji() {
    assert_eq_int(width("🚀"), 2)
}

fun test_char_width_values() {
    assert_eq_int(char_width(65), 1)
    assert_eq_int(char_width(19968), 2)
    assert_eq_int(char_width(769), 0)
    assert_eq_int(char_width(9), 0)
}

fun test_decode_ascii() {
    let c = decode("abc", 0)
    assert_eq_int(c.cp, 97)
    assert_eq_int(c.size, 1)
    assert_eq_int(c.width, 1)
}

fun test_decode_multibyte() {
    let c = decode("你", 0)
    assert_eq_int(c.cp, 20320)
    assert_eq_int(c.size, 3)
    assert_eq_int(c.width, 2)
}

fun test_decode_offset_walk() {
    let s = "a你b"
    let first = decode(s, 0)
    assert_eq_int(first.size, 1)
    let second = decode(s, first.size)
    assert_eq_int(second.cp, 20320)
    let third = decode(s, first.size + second.size)
    assert_eq_int(third.cp, 98)
}

fun test_decode_past_end() {
    let c = decode("x", 5)
    assert_eq_int(c.size, 0)
    assert_eq_int(c.width, 0)
}

fun test_decode_truncated_sequence() {
    // The first two bytes of a three byte character decode as U+FFFD.
    let broken = "你".substring(0, 2)
    let c = decode(broken, 0)
    assert_eq_int(c.cp, 65533)
    assert_eq_int(c.size, 1)
}

fun test_visible_width_skips_sgr() {
    assert_eq_int(visible_width("\u{1b}[31mred\u{1b}[0m"), 3)
}

fun test_visible_width_skips_osc() {
    assert_eq_int(visible_width("\u{1b}]0;title\u{7}x"), 1)
}

fun test_visible_width_plain_matches_width() {
    assert_eq_int(visible_width("plain 你"), width("plain 你"))
}

fun test_truncate_ascii() {
    assert_eq_str(truncate("hello", 3), "hel")
}

fun test_truncate_whole_fits() {
    assert_eq_str(truncate("abc", 10), "abc")
}

fun test_truncate_zero() {
    assert_eq_str(truncate("abc", 0), "")
}

fun test_truncate_wide_boundary() {
    assert_eq_str(truncate("你好吗", 4), "你好")
    // A wide character never straddles the limit.
    assert_eq_str(truncate("你好", 3), "你")
}

fun test_pad_right_wide() {
    assert_eq_str(pad_right("你", 4), "你  ")
    assert_eq_int(width(pad_right("你", 4)), 4)
}

fun test_pad_right_already_wide_enough() {
    assert_eq_str(pad_right("hello", 3), "hello")
}

fun test_pad_left() {
    assert_eq_str(pad_left("ab", 4), "  ab")
}

fun test_center_even() {
    assert_eq_str(center("ab", 6), "  ab  ")
}

fun test_center_odd_leans_left() {
    assert_eq_str(center("a", 4), " a  ")
}
